8:["$","div",null,{"className":"bg-white p-6 rounded-xl","children":[["$","h2",null,{"className":"text-lg font-bold text-[#2c2c2c] mb-4","children":"Popular Pages"}],["$","div",null,{"className":"flex flex-wrap justify-center gap-3","children":[["$","a","/services/",{"href":"/services/","className":"px-4 py-2 bg-[#f5f0e6] text-[#2c2c2c] rounded-lg hover:bg-[#c9b896] transition-colors","children":"Our Services"}],["$","a","/services/porcelain-patios/",{"href":"/services/porcelain-patios/","className":"px-4 py-2 bg-[#f5f0e6] text-[#2c2c2c] rounded-lg hover:bg-[#c9b896] transition-colors","children":"Porcelain Patios"}],["$","a","/about/",{"href":"/about/","className":"px-4 py-2 bg-[#f5f0e6] text-[#2c2c2c] rounded-lg hover:bg-[#c9b896] transition-colors","children":"About Us"}],["$","a","/testimonials/",{"href":"/testimonials/","className":"px-4 py-2 bg-[#f5f0e6] text-[#2c2c2c] rounded-lg hover:bg-[#c9b896] transition-colors","children":"Testimonials"}],["$","a","/areas/",{"href":"/areas/","className":"px-4 py-2 bg-[#f5f0e6] text-[#2c2c2c] rounded-lg hover:bg-[#c9b896] transition-colors","children":"Areas We Cover"}],["$","a","/contact/",{"href":"/contact/","className":"px-4 py-2 bg-[#f5f0e6] text-[#2c2c2c] rounded-lg hover:bg-[#c9b896] transition-colors","children":"Contact Us"}]]}]]}]
